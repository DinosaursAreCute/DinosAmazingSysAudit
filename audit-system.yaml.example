store:
  path: null
  retention_days: 90
collectors:
  auditd:
    enabled: true
  journalctl:
    enabled: true
  docker:
    enabled: true
    verbosity: normal
    correlate_logs: true
  stat:
    enabled: true
watched_paths:
- /etc
- /usr/bin/docker
- /usr/bin/docker-compose
- /run/docker.sock
- /var/lib/docker
report:
  formats:
  - html
  - csv
  - json
  output_dir: null
timezone: local
host_label: null
